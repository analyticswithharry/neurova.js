{
  "name": "neurova",
  "version": "0.1.0",
  "description": "neurova — the powerful TypeScript framework for AI-native apps. UI + Backend + AI in one import.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.cjs"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "import": "./dist/ui.js",
      "require": "./dist/ui.cjs"
    },
    "./backend": {
      "types": "./dist/backend.d.ts",
      "import": "./dist/backend.js",
      "require": "./dist/backend.cjs"
    },
    "./ai": {
      "types": "./dist/ai.d.ts",
      "import": "./dist/ai.js",
      "require": "./dist/ai.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": { "access": "public", "provenance": true },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@neurova/core": "workspace:*",
    "@neurova/ai": "workspace:*",
    "@neurova/backend": "workspace:*",
    "@neurova/ui": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "devDependencies": {
    "@neurova/tsconfig": "workspace:*",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3"
  },
  "author": "@analyticswithharry and Squid Consultancy Group Ltd",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/analyticswithharry/neurova.js.git",
    "directory": "packages/neurova"
  },
  "keywords": [
    "neurova",
    "ai",
    "ui",
    "framework",
    "typescript",
    "react",
    "fastify",
    "rag",
    "agents"
  ]
}
