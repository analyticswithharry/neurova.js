{
  "name": "@neurova/themes",
  "version": "0.1.0",
  "description": "Design tokens and theme presets for neurova",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": ["*.css"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./light.css": "./dist/light.css",
    "./dark.css": "./dist/dark.css"
  },
  "files": ["dist", "README.md"],
  "publishConfig": { "access": "public", "provenance": true },
  "scripts": {
    "build": "tsup && cp src/*.css dist/",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "@neurova/tsconfig": "workspace:*",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  },
  "author": "@analyticswithharry and Squid Consultancy Group Ltd",
  "license": "MIT"
}
