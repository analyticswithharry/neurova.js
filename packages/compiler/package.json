{
  "name": "@neurova/compiler",
  "version": "0.1.0",
  "description": "neurova compiler — parses .nv single-file components and emits JavaScript targeting either @neurova/runtime or React.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "neurova-compile": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": { "access": "public", "provenance": true },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "@neurova/tsconfig": "workspace:*",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  },
  "author": "@analyticswithharry and Squid Consultancy Group Ltd",
  "license": "MIT",
  "homepage": "https://neurova.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/analyticswithharry/neurova.js.git",
    "directory": "packages/compiler"
  },
  "keywords": ["neurova", "compiler", "dsl", "framework", "single-file-component"]
}
