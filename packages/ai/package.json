{
  "name": "@neurova/ai",
  "version": "0.1.0",
  "description": "neurova AI — chat, embeddings, vector store, RAG, agents, tracing. Provider-agnostic.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./chat": {
      "types": "./dist/chat.d.ts",
      "import": "./dist/chat.js",
      "require": "./dist/chat.cjs"
    },
    "./embed": {
      "types": "./dist/embed.d.ts",
      "import": "./dist/embed.js",
      "require": "./dist/embed.cjs"
    },
    "./vector": {
      "types": "./dist/vector.d.ts",
      "import": "./dist/vector.js",
      "require": "./dist/vector.cjs"
    },
    "./rag": {
      "types": "./dist/rag.d.ts",
      "import": "./dist/rag.js",
      "require": "./dist/rag.cjs"
    },
    "./agents": {
      "types": "./dist/agents.d.ts",
      "import": "./dist/agents.js",
      "require": "./dist/agents.cjs"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.js",
      "require": "./dist/providers/index.cjs"
    },
    "./tracing": {
      "types": "./dist/tracing.d.ts",
      "import": "./dist/tracing.js",
      "require": "./dist/tracing.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": { "access": "public", "provenance": true },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@neurova/core": "workspace:*"
  },
  "devDependencies": {
    "@neurova/tsconfig": "workspace:*",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  },
  "author": "@analyticswithharry",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/analyticswithharry/neurova.js.git",
    "directory": "packages/ai"
  },
  "keywords": [
    "neurova",
    "ai",
    "llm",
    "rag",
    "agents",
    "embeddings",
    "vector",
    "openai",
    "anthropic",
    "ollama"
  ]
}
