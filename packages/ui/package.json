{
  "name": "@neurova/ui",
  "version": "0.1.0",
  "description": "neurova UI — React 19 components, SSR-safe, accessible, themeable",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": ["*.css"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "import": "./dist/hooks.js",
      "require": "./dist/hooks.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": { "access": "public", "provenance": true },
  "scripts": {
    "build": "tsup && cp src/styles.css dist/",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@neurova/core": "workspace:*",
    "@neurova/icons": "workspace:*",
    "@neurova/themes": "workspace:*"
  },
  "devDependencies": {
    "@neurova/tsconfig": "workspace:*",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  },
  "author": "@analyticswithharry",
  "license": "MIT",
  "homepage": "https://neurova.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/analyticswithharry/neurova.js.git",
    "directory": "packages/ui"
  },
  "keywords": ["neurova", "ui", "react", "components", "design-system", "accessible"]
}
