{
  "name": "neurova-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "neurova — a unified UI + Backend + AI library for the modern web",
  "author": "@analyticswithharry and Squid Consultancy Group Ltd",
  "license": "MIT",
  "homepage": "https://neurova.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/analyticswithharry/neurova.js.git"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build --filter=./packages/* && pnpm -r --filter=./packages/* publish --access public --no-git-checks"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.9",
    "@types/node": "^22.7.5",
    "tsup": "^8.3.0",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
}
