{
  "name": "@neurova/cli",
  "version": "2.2.2",
  "description": "neurova command-line interface",
  "type": "module",
  "bin": {
    "neurova": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": ["dist", "README.md", "LICENSE", "templates"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@neurova/core": "workspace:*"
  },
  "devDependencies": {
    "@neurova/tsconfig": "workspace:*",
    "@types/node": "^22.7.5",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "author": "@analyticswithharry and Squid Consultancy Group Ltd",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/analyticswithharry/neurova.js.git",
    "directory": "packages/cli"
  },
  "keywords": ["neurova", "cli", "scaffold"]
}
