{
  "name": "@neurova/backend",
  "version": "2.2.2",
  "description": "neurova backend — Fastify-powered server kit with auth, db, queue, sockets, validation",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js",
      "require": "./dist/auth.cjs"
    },
    "./cache": {
      "types": "./dist/cache.d.ts",
      "import": "./dist/cache.js",
      "require": "./dist/cache.cjs"
    },
    "./queue": {
      "types": "./dist/queue.d.ts",
      "import": "./dist/queue.js",
      "require": "./dist/queue.cjs"
    },
    "./socket": {
      "types": "./dist/socket.d.ts",
      "import": "./dist/socket.js",
      "require": "./dist/socket.cjs"
    },
    "./rate-limit": {
      "types": "./dist/rate-limit.d.ts",
      "import": "./dist/rate-limit.js",
      "require": "./dist/rate-limit.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@neurova/core": "workspace:*",
    "fastify": "^5.0.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/jwt": "^9.0.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@neurova/tsconfig": "workspace:*",
    "@types/ws": "^8.5.13",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "author": "@analyticswithharry and Squid Consultancy Group Ltd",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/analyticswithharry/neurova.js.git",
    "directory": "packages/backend"
  },
  "keywords": [
    "neurova",
    "backend",
    "fastify",
    "server",
    "auth",
    "queue",
    "websocket"
  ]
}
